# DeepSeek API Key (required)
DEEPSEEK_API_KEY=sk-...
# DeepSeek API Base URL (optional, default shown)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OneDrive GoodNotes folder to watch (optional, default shown)
# GOODNOTES_WATCH_DIR=~/Library/CloudStorage/OneDrive-个人/GoodNotes

# Output directory (optional, default is data/output)
# OUTPUT_DIR=data/output
